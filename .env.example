# Sense account credentials (required unless SENSE_MOCK=1)
SENSE_EMAIL=
SENSE_PASSWORD=

# Server
PORT=3000
DATA_DIR=./data

# Locale
TZ=America/Edmonton
CURRENCY=CAD
ELECTRICITY_RATE_CENTS_PER_KWH=16.5

# Set to 1 to run against recorded fixtures instead of Sense's cloud (development)
SENSE_MOCK=0

# Realtime strategy: "persistent" (default) or "duty-cycle" (connect 50s, sleep 10s)
REALTIME_MODE=persistent
